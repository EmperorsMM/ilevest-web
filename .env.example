# =============================================================================
# .env.example  —  CANONICAL list of environment variables (NO REAL VALUES HERE)
# Copy to apps/web/.env.local for local dev and fill from the team secret store.
# Real values live in Vercel (runtime) and GitHub Secrets (CI). See infra/README.md.
# =============================================================================

# --- Supabase (per environment: dev / staging / prod) ---
# The project URL. Not secret, but environment-specific.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"

# CLIENT-SAFE key. Shipped to browsers/phones. RLS is what protects data, not this key.
# (Supabase also offers newer "publishable" keys, e.g. sb_publishable_...; same role.)
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-anon-or-publishable-key"

# SERVER-ONLY MASTER KEY. Bypasses ALL Row-Level Security. NEVER prefix with NEXT_PUBLIC_,
# never ship to the client, never commit. Leaking this defeats the entire trust model.
# (Supabase also offers newer "secret" keys, e.g. sb_secret_...; same danger.)
SUPABASE_SERVICE_ROLE_KEY="YOUR-service-role-or-secret-key__SERVER_ONLY"

# Direct Postgres connection string — used ONLY by migrations / CI, never by the browser.
SUPABASE_DB_URL="postgresql://postgres:[password]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres"

# --- Payment gateway (Category 1 money layer — added in a later stage, names reserved) ---
# PAYSTACK_SECRET_KEY="SERVER_ONLY"
# PAYSTACK_WEBHOOK_SECRET="SERVER_ONLY"
